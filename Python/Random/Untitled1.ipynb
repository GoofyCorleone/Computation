   "source": [
    "import math as mt\n",
    "\n",
    "def binom (n,k,p):\n",
    "    suma = 0\n",
    "    for i in range (0,k+1):\n",
    "        a = (mt.factorial(n)/(mt.factorial(i)*mt.factorial(n-i)) * (p) **i * (1-p)**(n-i))\n",
    "        suma += a\n",
    "        print(a)\n",
    "    print('Suma total: ',suma)\n",
    "binom(18,4,0.27)"
   ]
  }
